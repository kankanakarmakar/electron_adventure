# Museum Circuit Display System Configuration
# Version: 2.1 - Production Ready
# Last Updated: January 20, 2026

# ============================================
# SYSTEM CONFIGURATION
# ============================================

# Environment
NODE_ENV=production
DEBUG=false

# ============================================
# PORT CONFIGURATION
# ============================================

# WebSocket Server Port
WS_PORT=8081

# Display Screen Port
DISPLAY_PORT=3001

# Control Panel Port
CONTROL_PORT=3002

# ============================================
# NETWORK CONFIGURATION
# ============================================

# WebSocket Server Host (for client connections)
# Leave as 'localhost' for single machine
# Change to server IP for multi-machine setup (e.g., '192.168.1.50')
VITE_WS_HOST=localhost
VITE_WS_PORT=8081

# Use this to connect from different machines:
# Linux/macOS: export VITE_WS_HOST=192.168.1.50
# Windows:     set VITE_WS_HOST=192.168.1.50

# ============================================
# APPLICATION SETTINGS
# ============================================

# Application Name
VITE_APP_NAME=Museum Circuit Display

# Application Version
VITE_APP_VERSION=2.1.0

# Display Mode (fullscreen recommended for museums)
VITE_FULLSCREEN=true

# Animation Speed (0.5-2.0, default 1.0)
VITE_ANIMATION_SPEED=1.0

# Default Circuit Type
VITE_DEFAULT_CIRCUIT=resistor

# ============================================
# FEATURE FLAGS
# ============================================

# Enable debug mode (shows console logs)
VITE_DEBUG_MODE=false

# Show state monitor on display screen
VITE_SHOW_STATE_MONITOR=true

# Enable connection status indicator
VITE_SHOW_CONNECTION_STATUS=true

# Auto-connect on page load
VITE_AUTO_CONNECT=true

# ============================================
# CIRCUIT PARAMETERS
# ============================================

# Default Voltage (0-12V)
VITE_DEFAULT_VOLTAGE=5

# Default Frequency (Hz)
VITE_DEFAULT_FREQUENCY=50

# Default Resistance (Ohms)
VITE_DEFAULT_RESISTANCE=100

# Default Capacitance (μF)
VITE_DEFAULT_CAPACITANCE=1

# Default Inductance (H)
VITE_DEFAULT_INDUCTANCE=0.1

# ============================================
# PERFORMANCE SETTINGS
# ============================================

# WebSocket Reconnect Attempts
WS_RECONNECT_ATTEMPTS=5

# WebSocket Reconnect Delay (ms)
WS_RECONNECT_DELAY=1000

# WebSocket Heartbeat Interval (ms)
WS_HEARTBEAT_INTERVAL=30000

# State Update Interval (ms)
STATE_UPDATE_INTERVAL=500

# ============================================
# MUSEUM-SPECIFIC SETTINGS
# ============================================

# Museum Name (for branding)
MUSEUM_NAME=Educational Museum

# Location/Gallery Name
MUSEUM_LOCATION=Electronics Gallery

# Operating Hours (for displays)
MUSEUM_HOURS=09:00-17:00

# Automatic Display Mode (turns off after hours)
AUTO_DISPLAY_MODE=false

# ============================================
# SECURITY SETTINGS
# ============================================

# Enable CORS (for cross-origin requests)
ENABLE_CORS=false

# Enable rate limiting
ENABLE_RATE_LIMIT=false

# Max connections per IP
MAX_CONNECTIONS_PER_IP=10

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log Level (error, warn, info, debug, trace)
LOG_LEVEL=info

# Log File Path (leave empty to disable file logging)
LOG_FILE=./logs/museum-display.log

# Keep Log Files (days)
LOG_RETENTION=7

# ============================================
# HARDWARE INTEGRATION
# ============================================

# GPIO Hardware Buttons Enabled
GPIO_ENABLED=false

# GPIO Library (rpio, pigpio, gpiozero)
GPIO_LIBRARY=rpio

# Button Pin Mapping (GPIO pins for hardware buttons)
# Format: ACTION=GPIO_PIN
# Examples:
# BUTTON_VOLTAGE_INC=17
# BUTTON_VOLTAGE_DEC=18
# BUTTON_FREQUENCY_INC=27
# BUTTON_FREQUENCY_DEC=22
# BUTTON_RESISTOR=23
# BUTTON_CAPACITOR=24
# BUTTON_INDUCTOR=25
# BUTTON_DIODE=26
# BUTTON_RESET=12

# ============================================
# DEPLOYMENT METHOD
# ============================================

# Choose deployment:
# 1 = All-in-One (default, single machine)
# 2 = Server only
# 3 = Display only
# 4 = Control only
# 5 = Multi-machine
DEPLOYMENT_METHOD=1

# ============================================
# DATABASE (Optional, for future features)
# ============================================

# Enable data persistence
DATABASE_ENABLED=false

# Database Type (sqlite, postgres, mysql)
DATABASE_TYPE=sqlite

# Database Path (for SQLite)
DATABASE_PATH=./data/museum.db

# ============================================
# EXTERNAL INTEGRATIONS
# ============================================

# Analytics Enabled
ANALYTICS_ENABLED=false

# API Server (for future API integration)
API_ENABLED=false
API_HOST=localhost
API_PORT=3000

# ============================================
# DEVELOPMENT SETTINGS (Not used in production)
# ============================================

# Dev Server Port
DEV_PORT=5173

# Enable Hot Module Replacement
HMR_ENABLED=true

# Enable Source Maps
SOURCE_MAPS=false

# ============================================
# NOTES
# ============================================

# Single Machine Deployment:
# Simply run: npm run start:museum
# Everything will use localhost

# Multi-Machine Deployment:
# 1. Set VITE_WS_HOST to server IP (e.g., 192.168.1.50)
# 2. Run server on machine with public IP
# 3. Display and control machines connect to that IP
#
# Example:
#   Server machine:   npm run server
#   Display machine:  VITE_WS_HOST=192.168.1.50 npm run dev:display
#   Control machine:  VITE_WS_HOST=192.168.1.50 npm run dev:control

# Hardware Button Integration:
# 1. Set GPIO_ENABLED=true
# 2. Configure GPIO pins for each button
# 3. Connect buttons to Raspberry Pi or similar
# 4. See MUSEUM_DISPLAY_SETUP.md for wiring diagram

# ============================================
# QUICK REFERENCE
# ============================================

# Start all-in-one:
# npm run start:museum

# Start individual services:
# npm run server                    (WebSocket on 8081)
# npm run dev:display              (Display on 3001)
# npm run dev:control              (Control on 3002)

# Production preview:
# npm run preview:display          (optimized, on 3001)
# npm run preview:control          (optimized, on 3002)

# Build production:
# npm run build:all

# Check server health:
# curl http://localhost:8081/health

# Access screens:
# Display:  http://localhost:3001
# Control:  http://localhost:3002

# For network access, replace 'localhost' with machine IP or hostname

